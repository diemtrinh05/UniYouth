{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "UniYouth.Admin.Filters": "Debug"
        }
    },
    "AllowedHosts": "*",

    // Cấu hình API Backend
    // BaseUrl: Địa chỉ của UniYouth.Api
    // Cần thay đổi theo môi trường (Development, Staging, Production)
    "ApiSettings": {
        "BaseUrl": "",
        "PublicBaseUrl": "",
        "AssetBaseUrl": "",
        "Timeout": 30
    },

    "GoogleMaps": {
        "ApiKey": ""
    },

    "FileUpload": {
        "MaxFileSize": 3145728,
        "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
        "AllowedMimeTypes": [ "image/jpeg", "image/png", "image/webp" ]
    },
    // Cấu hình Cookie
    // Secure: true trong Production (chỉ gửi qua HTTPS)
    // Secure: false trong Development (cho phép HTTP)
    "CookieSettings": {
        "Secure": false,
        "SameSite": "Strict"
    },

    // Cấu hình JWT
    // QUAN TRỌNG: SecretKey phải GIỐNG với Backend API
    // Trong thực tế, nên lưu trong User Secrets hoặc Azure Key Vault
    "JwtSettings": {
        "SecretKey": "",
        "Issuer": "UniYouth.Api",
        "Audience": "UniYouth.Client",
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateLifetime": true
    }
}
