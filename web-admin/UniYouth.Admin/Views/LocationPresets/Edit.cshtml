@model UniYouth.Admin.Models.ViewModels.LocationPresets.UpdateLocationPresetForm
@{
    ViewData["Title"] = "Cập nhật vị trí định sẵn";
    ViewData["PageIcon"] = "bi bi-geo-alt";
    ViewData["PageSubtitle"] = "Điều chỉnh tọa độ, bán kính và trạng thái sử dụng của vị trí.";
    var returnUrl = ViewBag.ReturnUrl as string;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
}

<partial name="_Alerts" />

<div class="d-flex justify-content-between align-items-start gap-3 mb-3">
    <partial name="UI/_PageHeader" />
    <a class="btn btn-outline-secondary"
       href="@(string.IsNullOrWhiteSpace(returnUrl) ? Url.Action("Index") : returnUrl)">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="card uy-section-card">
    <div class="card-header bg-light uy-section-card-header">
        <strong class="uy-section-card-title"><i class="bi bi-pencil-square me-2"></i>Thông tin vị trí định sẵn</strong>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="LocationPresetId" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <div class="col-md-4">
                <label class="form-label">Tên</label>
                <input class="form-control" asp-for="Name" />
                <span class="text-danger small" asp-validation-for="Name"></span>
            </div>
            <div class="col-md-8">
                <label class="form-label">Địa chỉ (tùy chọn)</label>
                <input class="form-control" asp-for="Address" />
                <span class="text-danger small" asp-validation-for="Address"></span>
            </div>

            <div class="col-md-3">
                <label class="form-label">Vĩ độ</label>
                <div class="input-group">
                    <input class="form-control" asp-for="Latitude" readonly />
                    <button id="btnUseGpsEdit" type="button" class="btn btn-outline-primary" aria-label="Dùng GPS để lấy tọa độ vị trí định sẵn">
                        <i class="bi bi-geo-alt"></i> Dùng GPS
                    </button>
                </div>
                <span class="text-danger small" asp-validation-for="Latitude"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label">Kinh độ</label>
                <input class="form-control" asp-for="Longitude" readonly />
                <span class="text-danger small" asp-validation-for="Longitude"></span>
                <div id="gpsStatusEdit" class="form-text text-muted"></div>
            </div>

            <div class="col-12">
                <button class="btn btn-outline-secondary"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#locationPresetMapEditCollapse"
                        aria-expanded="false"
                        aria-controls="locationPresetMapEditCollapse"
                        aria-label="Mở bản đồ để chọn tọa độ vị trí định sẵn">
                    <i class="bi bi-map me-1"></i>Chọn vị trí trên bản đồ
                </button>
                <small class="text-muted ms-2">Bấm để mở bản đồ và chọn tọa độ.</small>
            </div>
            <div class="col-12">
                <div id="locationPresetMapEditCollapse" class="collapse">
                    <div class="border rounded p-3 bg-light">
                        <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-2">
                            <strong><i class="bi bi-geo me-1"></i>Bản đồ</strong>
                            <button id="btnUseMyLocationEdit" type="button" class="btn btn-sm btn-outline-primary" aria-label="Dùng vị trí hiện tại trên bản đồ">
                                <i class="bi bi-crosshair me-1"></i>Vị trí hiện tại
                            </button>
                        </div>
                        <div id="locationPresetMapEdit" class="location-presets-map"></div>
                        <div class="location-presets-map-meta mt-2 small text-muted">
                            <span id="locationPresetCoordsEdit">Chưa chọn vị trí</span>
                            <span id="locationPresetStatusEdit"></span>
                        </div>
                        <div class="form-text mt-1">
                            Bấm lên bản đồ để chọn tọa độ; trường <strong>Địa chỉ</strong> sẽ tự cập nhật.
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label">Bán kính (m)</label>
                <input class="form-control" asp-for="RadiusMeters" />
                <span class="text-danger small" asp-validation-for="RadiusMeters"></span>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                    <label class="form-check-label" asp-for="IsActive">Kích hoạt</label>
                </div>
            </div>

            <div class="col-12">
                <button class="btn btn-primary" type="submit" aria-label="Lưu vị trí định sẵn">
                    <i class="bi bi-save me-1"></i>Lưu
                </button>
                <a class="btn btn-outline-secondary"
                   href="@(string.IsNullOrWhiteSpace(returnUrl) ? Url.Action("Index") : returnUrl)"
                   aria-label="Hủy chỉnh sửa vị trí định sẵn">
                    Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_GoogleMapsScript" />
    <script src="~/js/event-location-picker.js" asp-append-version="true"></script>
    <script src="~/js/location-presets-gps.js" asp-append-version="true"></script>
    <script src="~/js/location-presets-edit.js" asp-append-version="true"></script>
}
