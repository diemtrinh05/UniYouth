<div class="modal fade" id="eventQrPreviewModal" tabindex="-1" aria-labelledby="eventQrPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content uy-confirm-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="eventQrPreviewModalLabel">
                    <i class="bi bi-qr-code me-2"></i>Mã QR sự kiện
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng modal mã QR sự kiện"></button>
            </div>
            <div class="modal-body p-4">
                <div id="eventQrPreviewLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="mt-3 text-muted">Đang tải QR code...</div>
                </div>

                <div id="eventQrPreviewError" class="alert alert-warning d-none mb-0" role="alert">
                    <div class="fw-semibold mb-1">Không thể hiển thị QR code</div>
                    <div id="eventQrPreviewErrorMessage"></div>
                </div>

                <div id="eventQrPreviewContent" class="d-none">
                    <div class="text-center mb-3">
                        <div class="fw-bold text-dark" id="eventQrPreviewEventName"></div>
                        <div class="small text-muted mt-1" id="eventQrPreviewTimeRange"></div>
                    </div>
                    <div class="text-center">
                        <img id="eventQrPreviewImage"
                             alt="Mã QR sự kiện"
                             class="img-fluid border rounded-4 bg-white p-3 home-qr-preview-image" />
                    </div>
                    <div class="row g-2 mt-3 small text-muted">
                        <div class="col-6">
                            <div class="fw-semibold text-dark">Số lượt quét</div>
                            <div id="eventQrPreviewScanCount">-</div>
                        </div>
                        <div class="col-6">
                            <div class="fw-semibold text-dark">Giới hạn</div>
                            <div id="eventQrPreviewScanLimit">-</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" aria-label="Đóng modal mã QR sự kiện">Đóng</button>
            </div>
        </div>
    </div>
</div>
