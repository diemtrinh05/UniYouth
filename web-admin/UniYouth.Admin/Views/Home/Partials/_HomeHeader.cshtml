@model UniYouth.Admin.Models.ViewModels.Home.HomeOverviewViewModel

<div class="home-header mb-4">
    <div class="row align-items-center">
        <div class="col-12">
            <div class="welcome-message">
                <h1 class="h3 mb-1 fw-bold home-welcome-title">
                    <span class="home-welcome-icon">
                        <i class="bi bi-sun" aria-hidden="true"></i>
                    </span>
                    @Model.Greeting, <span class="home-welcome-name">@(ViewBag.CurrentUserFullName ?? "Bạn")</span>!
                </h1>
                <p class="home-welcome-meta mb-0">
                    <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>
                    <span id="currentDate"></span> •
                    <span class="badge home-system-badge">
                        <i class="bi bi-circle-fill pulse-dot" aria-hidden="true"></i> Hệ thống hoạt động tốt
                    </span>
                </p>
            </div>
        </div>
    </div>
</div>
