@model UniYouth.Admin.Models.ViewModels.Attendance.EventAttendanceListViewModel

@{
    ViewData["Title"] = "Danh sách Điểm danh";

    var currentSortBy = Model.SortBy;
    var currentSortDir = Model.SortDir;
    var sortCode = "code";
    var sortFullName = "fullName";
    var sortCheckInTime = "checkInTime";
    var sortIsValid = "isValid";

    string GetNextSortDir(string column)
    {
        if (string.Equals(currentSortBy, column, StringComparison.OrdinalIgnoreCase))
        {
            return string.Equals(currentSortDir, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
        }

        return "asc";
    }

    string GetSortIcon(string column)
    {
        if (!string.Equals(currentSortBy, column, StringComparison.OrdinalIgnoreCase))
        {
            return "bi bi-arrow-down-up text-muted";
        }

        return string.Equals(currentSortDir, "asc", StringComparison.OrdinalIgnoreCase)
            ? "bi bi-caret-up-fill text-primary"
            : "bi bi-caret-down-fill text-primary";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/attendance.css" asp-append-version="true" />
}

<partial name="_Alerts" />

<div class="container-fluid">
    <partial name="Partials/_AttendanceHeader" model="Model" />
    <partial name="Partials/_AttendanceStatistics" model="Model" />
    <partial name="Partials/_AttendanceFilters" model="Model" />

    <div class="row">
        <div class="col-12">
            <div class="card uy-section-card">
                <div class="card-header bg-light d-flex justify-content-between align-items-center uy-section-card-header">
                    <h5 class="mb-0 uy-section-card-title">
                        @{
                            var totalRecords = Model.Summary?.TotalRecords ?? Model.Pagination?.TotalCount;
                        }
                        <i class="bi bi-table me-2"></i>Danh sách Điểm danh (@(totalRecords?.ToString() ?? "—") bản ghi)
                    </h5>
                    <div>
                        <span class="badge bg-success me-2">
                            <i class="bi bi-check-circle me-1"></i>Hợp lệ: @(Model.Summary != null ? Model.Summary.ValidCount.ToString() : "—")
                        </span>
                        <span class="badge bg-danger me-2">
                            <i class="bi bi-x-circle me-1"></i>Không hợp lệ: @(Model.Summary != null ? Model.Summary.InvalidCount.ToString() : "—")
                        </span>
                        <span class="badge bg-dark me-2">
                            <i class="bi bi-shield-exclamation me-1"></i>Suspicious trang hiện tại: @Model.SuspiciousAttendances
                        </span>
                        <button class="btn btn-sm btn-outline-primary" type="button" data-attendance-export="true" aria-label="Xuất danh sách điểm danh ra Excel">
                            <i class="bi bi-file-earmark-excel me-1"></i>Xuất Excel
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    @if (!Model.HasAttendances)
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-person-x attendance-empty-icon"></i>
                            <h5 class="text-muted mt-3">Chưa có điểm danh</h5>
                            <p class="text-muted">Chưa có ai check-in cho sự kiện này.</p>
                        </div>
                    }
                    else
                    {
                        <partial name="Partials/_AttendanceReviewNote" model="Model" />

                        <div class="attendance-table-wrapper">
                            <table class="table table-hover align-middle" id="attendancesTable">
                                <caption class="visually-hidden">Danh sách điểm danh của sự kiện</caption>
                                <thead class="table-light">
                                    <tr>
                                        <th class="sticky-col sticky-col-1">#</th>
                                        <th class="sticky-col sticky-col-2">
                                            <a class="text-decoration-none text-dark"
                                               asp-action="Index"
                                               asp-route-eventId="@Model.EventId"
                                               asp-route-pageNumber="1"
                                               asp-route-pageSize="@Model.PageSize"
                                               asp-route-q="@Model.Q"
                                               asp-route-isValid="@Model.IsValid"
                                               asp-route-method="@Model.Method"
                                               asp-route-faceVerified="@Model.FaceVerified"
                                               asp-route-riskLevel="@Model.RiskLevel"
                                               asp-route-from="@(Model.From?.ToString("o"))"
                                               asp-route-to="@(Model.To?.ToString("o"))"
                                               asp-route-sortBy="@sortCode"
                                               asp-route-sortDir="@GetNextSortDir(sortCode)">
                                                Mã
                                                <i class="@GetSortIcon(sortCode) ms-1"></i>
                                            </a>
                                        </th>
                                        <th class="sticky-col sticky-col-3">
                                            <a class="text-decoration-none text-dark"
                                               asp-action="Index"
                                               asp-route-eventId="@Model.EventId"
                                               asp-route-pageNumber="1"
                                               asp-route-pageSize="@Model.PageSize"
                                               asp-route-q="@Model.Q"
                                               asp-route-isValid="@Model.IsValid"
                                               asp-route-method="@Model.Method"
                                               asp-route-faceVerified="@Model.FaceVerified"
                                               asp-route-riskLevel="@Model.RiskLevel"
                                               asp-route-from="@(Model.From?.ToString("o"))"
                                               asp-route-to="@(Model.To?.ToString("o"))"
                                               asp-route-sortBy="@sortFullName"
                                               asp-route-sortDir="@GetNextSortDir(sortFullName)">
                                                Họ và Tên
                                                <i class="@GetSortIcon(sortFullName) ms-1"></i>
                                            </a>
                                        </th>
                                        <th class="col-email">Email</th>
                                        <th class="col-time">
                                            <a class="text-decoration-none text-dark"
                                               asp-action="Index"
                                               asp-route-eventId="@Model.EventId"
                                               asp-route-pageNumber="1"
                                               asp-route-pageSize="@Model.PageSize"
                                               asp-route-q="@Model.Q"
                                               asp-route-isValid="@Model.IsValid"
                                               asp-route-method="@Model.Method"
                                               asp-route-faceVerified="@Model.FaceVerified"
                                               asp-route-riskLevel="@Model.RiskLevel"
                                               asp-route-from="@(Model.From?.ToString("o"))"
                                               asp-route-to="@(Model.To?.ToString("o"))"
                                               asp-route-sortBy="@sortCheckInTime"
                                               asp-route-sortDir="@GetNextSortDir(sortCheckInTime)">
                                                Thời gian Check-in
                                                <i class="@GetSortIcon(sortCheckInTime) ms-1"></i>
                                            </a>
                                        </th>
                                        <th>Phương thức</th>
                                        <th class="col-face">Face</th>
                                        <th class="col-ip">IP</th>
                                        <th class="col-device">Thiết bị</th>
                                        <th class="col-client-device-id">Client Device ID</th>
                                        <th class="col-risk">Rủi ro</th>
                                        <th class="col-distance">Khoảng cách</th>
                                        <th class="col-validity">
                                            <a class="text-decoration-none text-dark"
                                               asp-action="Index"
                                               asp-route-eventId="@Model.EventId"
                                               asp-route-pageNumber="1"
                                               asp-route-pageSize="@Model.PageSize"
                                               asp-route-q="@Model.Q"
                                               asp-route-isValid="@Model.IsValid"
                                               asp-route-method="@Model.Method"
                                               asp-route-faceVerified="@Model.FaceVerified"
                                               asp-route-riskLevel="@Model.RiskLevel"
                                               asp-route-from="@(Model.From?.ToString("o"))"
                                               asp-route-to="@(Model.To?.ToString("o"))"
                                               asp-route-sortBy="@sortIsValid"
                                               asp-route-sortDir="@GetNextSortDir(sortIsValid)">
                                                Trạng thái
                                                <i class="@GetSortIcon(sortIsValid) ms-1"></i>
                                            </a>
                                        </th>
                                        <th class="col-invalid-reason">Lý do Không hợp lệ</th>
                                        <th class="col-detail">Chi tiết</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var index = (Model.PageNumber - 1) * Model.PageSize + 1;
                                    }
                                    @foreach (var att in Model.Attendances)
                                    {
                                        <tr class="@att.TableRowClass">
                                            <td class="sticky-col sticky-col-1">@index</td>
                                            <td class="sticky-col sticky-col-2"><strong>@att.Code</strong></td>
                                            <td class="sticky-col sticky-col-3">@att.FullName</td>
                                            <td class="col-email">
                                                <small>
                                                    <a href="mailto:@att.Email" class="text-decoration-none">
                                                        @att.Email
                                                    </a>
                                                </small>
                                            </td>
                                            <td class="col-time">
                                                <small>
                                                    <i class="bi bi-clock me-1"></i>
                                                    @att.CheckInTime.ToString("dd/MM/yyyy HH:mm:ss")
                                                </small>
                                            </td>
                                            <td class="col-face">
                                                <span class="badge @att.MethodBadgeClass">@att.CheckInMethod</span>
                                            </td>
                                            <td class="col-ip">
                                                <div class="d-flex flex-column gap-1">
                                                    <span class="badge @att.FaceVerificationBadgeClass">
                                                        <i class="bi @att.FaceVerificationIcon me-1"></i>
                                                        @att.FaceVerificationDisplay
                                                    </span>
                                                    <small class="text-muted">Xác minh: @att.FaceVerifiedDisplay</small>
                                                    <small class="text-muted">Độ tin cậy: @att.FaceConfidenceDisplay</small>
                                                </div>
                                            </td>
                                            <td class="col-device">
                                                @if (!string.IsNullOrWhiteSpace(att.IpAddress))
                                                {
                                                    <code class="small">@att.IpAddress</code>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="col-client-device-id">
                                                @if (!string.IsNullOrWhiteSpace(att.DeviceInfo))
                                                {
                                                    <small class="text-muted" data-bs-toggle="tooltip" title="@att.DeviceInfo">@att.DeviceInfo</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="col-risk">
                                                @if (!string.IsNullOrWhiteSpace(att.ClientDeviceId))
                                                {
                                                    <code class="small text-break d-inline-block" data-bs-toggle="tooltip" title="@att.ClientDeviceId">@att.ClientDeviceId</code>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="col-distance">
                                                <div class="d-flex flex-column gap-1">
                                                    <span class="badge @att.RiskLevelBadgeClass">
                                                        <i class="bi @att.RiskIcon me-1"></i>
                                                        @att.RiskLevelDisplay
                                                    </span>
                                                    <small class="text-muted">Điểm: @att.RiskScoreDisplay</small>
                                                    @if (att.RiskReasons.Count > 0)
                                                    {
                                                        <small class="text-muted" data-bs-toggle="tooltip" title="@att.RiskReasonsDisplay">
                                                            @string.Join(", ", att.RiskReasons.Take(2))@(att.RiskReasons.Count > 2 ? "..." : string.Empty)
                                                        </small>
                                                    }
                                                </div>
                                            </td>
                                            <td class="col-validity">
                                                @if (att.Distance.HasValue)
                                                {
                                                    <strong>@att.DistanceDisplay</strong>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                            <td class="col-invalid-reason">
                                                <span class="badge @att.ValidityBadgeClass">
                                                    <i class="bi @att.ValidityIcon me-1"></i>
                                                    @att.ValidityDisplay
                                                </span>
                                            </td>
                                            <td class="col-detail">
                                                @if (!att.IsValid && !string.IsNullOrEmpty(att.InvalidReason))
                                                {
                                                    <small class="text-danger" data-bs-toggle="tooltip" title="@att.InvalidReason">
                                                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                                        @att.InvalidReason
                                                    </small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-secondary"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#attendanceDetailModal-@att.AttendanceID"
                                                        aria-label="Xem chi tiết điểm danh của @att.FullName">
                                                    <i class="bi bi-eye me-1"></i>Chi tiết
                                                </button>
                                            </td>
                                        </tr>
                                        index++;
                                    }
                                </tbody>
                            </table>
                        </div>

                        @foreach (var att in Model.Attendances)
                        {
                            <div class="modal fade" id="attendanceDetailModal-@att.AttendanceID" tabindex="-1" aria-labelledby="attendanceDetailModalLabel-@att.AttendanceID" aria-hidden="true">
                                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="attendanceDetailModalLabel-@att.AttendanceID">
                                                <i class="bi bi-person-vcard me-2"></i>Chi tiết điểm danh - @att.Code
                                            </h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng chi tiết điểm danh của @att.FullName"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <div class="border rounded p-3 h-100">
                                                        <h6 class="fw-semibold mb-3">Thông tin người điểm danh</h6>
                                                        <div><strong>Họ tên:</strong> @att.FullName</div>
                                                        <div><strong>Mã:</strong> @att.Code</div>
                                                        <div><strong>Email:</strong> @att.Email</div>
                                                        <div><strong>Thời gian:</strong> @att.CheckInTime.ToString("dd/MM/yyyy HH:mm:ss")</div>
                                                        <div><strong>Phương thức:</strong> @att.CheckInMethod</div>
                                                        <div><strong>Hợp lệ:</strong> @att.ValidityDisplay</div>
                                                        <div><strong>Lý do không hợp lệ:</strong> @(string.IsNullOrWhiteSpace(att.InvalidReason) ? "-" : att.InvalidReason)</div>
                                                        <div><strong>Khoảng cách:</strong> @att.DistanceDisplay</div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="border rounded p-3 h-100">
                                                        <h6 class="fw-semibold mb-3">Tóm tắt khuôn mặt</h6>
                                                        <div class="mb-2">
                                                            <span class="badge @att.FaceVerificationBadgeClass">
                                                                <i class="bi @att.FaceVerificationIcon me-1"></i>
                                                                @att.FaceVerificationDisplay
                                                            </span>
                                                        </div>
                                                        <div><strong>Xác minh:</strong> @att.FaceVerifiedDisplay</div>
                                                        <div><strong>Độ tin cậy:</strong> @att.FaceConfidenceDisplay</div>
                                                        <div><strong>Trạng thái raw:</strong> @(string.IsNullOrWhiteSpace(att.FaceVerificationStatus) ? "-" : att.FaceVerificationStatus)</div>
                                                        <div><strong>Provider:</strong> @att.FaceVerificationProviderDisplay</div>
                                                        <div><strong>Version:</strong> @att.FaceVerificationVersionDisplay</div>
                                                        <div><strong>Lý do:</strong> @att.FaceVerificationReasonDisplay</div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="border rounded p-3 h-100">
                                                        <h6 class="fw-semibold mb-3">Tóm tắt rủi ro</h6>
                                                        <div class="mb-2">
                                                            <span class="badge @att.RiskLevelBadgeClass">
                                                                <i class="bi @att.RiskIcon me-1"></i>
                                                                @att.RiskLevelDisplay
                                                            </span>
                                                        </div>
                                                        <div><strong>Điểm rủi ro:</strong> @att.RiskScoreDisplay</div>
                                                        <div><strong>Lý do rủi ro:</strong></div>
                                                        @if (att.RiskReasons.Count > 0)
                                                        {
                                                            <ul class="mb-0 ps-3">
                                                                @foreach (var reason in att.RiskReasons)
                                                                {
                                                                    <li>@reason</li>
                                                                }
                                                            </ul>
                                                        }
                                                        else
                                                        {
                                                            <div>-</div>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="border rounded p-3 h-100 bg-light">
                                                        <h6 class="fw-semibold mb-3">Gợi ý review</h6>
                                                        <div class="mb-2">
                                                            @if (att.NeedsManualReview)
                                                            {
                                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                                                    <i class="bi bi-search me-1"></i>Cần review thủ công
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-success-subtle text-success border border-success-subtle">
                                                                    <i class="bi bi-check2-circle me-1"></i>Không có tín hiệu review bổ sung
                                                                </span>
                                                            }
                                                        </div>
                                                        <div><strong>Focus:</strong> @att.ReviewFocusDisplay</div>
                                                        <ul class="mb-0 mt-2 ps-3">
                                                            <li>Đối chiếu face status, provider/version và reason trước khi kết luận.</li>
                                                            <li>Kiểm tra risk reasons, IP, thiết bị và client device ID cho cùng người dùng.</li>
                                                            <li>Ưu tiên escalation nếu là `Mismatch`, `TechnicalError` lặp lại hoặc `Critical`.</li>
                                                        </ul>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="border rounded p-3 h-100">
                                                        <h6 class="fw-semibold mb-3">Thiết bị / mạng</h6>
                                                        <div><strong>IP address:</strong> @(string.IsNullOrWhiteSpace(att.IpAddress) ? "-" : att.IpAddress)</div>
                                                        <div><strong>Device info:</strong> @(string.IsNullOrWhiteSpace(att.DeviceInfo) ? "-" : att.DeviceInfo)</div>
                                                        <div><strong>Client device ID:</strong> @(string.IsNullOrWhiteSpace(att.ClientDeviceId) ? "-" : att.ClientDeviceId)</div>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="border rounded p-3 h-100">
                                                        <h6 class="fw-semibold mb-3">GPS</h6>
                                                        <div><strong>Latitude:</strong> @(att.UserLatitude?.ToString("N6") ?? "-")</div>
                                                        <div><strong>Longitude:</strong> @(att.UserLongitude?.ToString("N6") ?? "-")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <partial name="_Pagination" model="new PaginationViewModel { PageNumber = Model.PageNumber, TotalPages = Model.TotalPages }" />
                        <partial name="Partials/_AttendanceLegend" model="Model" />

                        <div class="alert alert-warning mt-3 mb-0">
                            <i class="bi bi-shield-lock me-2"></i>
                            <strong>Quan trọng:</strong> Trang này chỉ để xem dữ liệu điểm danh.
                            Dữ liệu đã được validate khi check-in và KHÔNG THỂ sửa đổi để đảm bảo tính toàn vẹn.
                            Nếu phát hiện sai sót, vui lòng liên hệ quản trị viên để xử lý qua quy trình chính thức.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/attendance-index.js"
            asp-append-version="true"
            data-attendance-export-file-name="DanhSachDiemDanh_Event@(Model.EventId)_@(DateTime.Now.ToString("yyyyMMdd")).csv"></script>
}
