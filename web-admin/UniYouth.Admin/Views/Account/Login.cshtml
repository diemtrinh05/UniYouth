@using UniYouth.Admin.Models.ViewModels.Auth
@model LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "_AuthLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-login.css" asp-append-version="true" />
}
    <div class="login-wrapper">
        <div class="login-card">
            <!-- Header -->
            <div class="login-header">
                <div class="logo-wrapper">
                    <i class="bi bi-mortarboard-fill"></i>
                </div>
                <h1>UniYouth Admin</h1>
                <p>Hệ thống quản lý hoạt động đoàn hội</p>
            </div>

            <!-- Body -->
            <div class="login-body">
                <div class="welcome-text">
                    <h2>Chào mừng trở lại!</h2>
                    <p>Đăng nhập để tiếp tục quản lý hệ thống</p>
                </div>

                <!-- Alert -->
                <partial name="_Alerts" />

                @if (ViewData["Message"] != null)
                {
                    <div class="alert alert-info" role="alert">
                        @ViewData["Message"]
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger" role="alert">
                        <div asp-validation-summary="All"></div>
                    </div>
                }
                

                <form asp-action="Login" method="post" id="loginForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />

                    <!-- Tài khoản -->
                    <div class="form-group">
                        <label asp-for="Code" class="form-label">
                            <i class="bi bi-person-badge"></i>
                            Tài khoản
                        </label>
                        <div class="input-wrapper">
                            <i class="bi bi-person input-icon"></i>
                            <input asp-for="Code"
                                   class="form-control"
                                   placeholder="Nhập tài khoản của bạn"
                                   autocomplete="username"
                                   autofocus />
                        </div>
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <!-- Mật khẩu -->
                    <div class="form-group">
                        <label asp-for="Password" class="form-label">
                            <i class="bi bi-shield-lock"></i>
                            Mật khẩu
                        </label>
                        <div class="input-wrapper">
                            <i class="bi bi-lock input-icon"></i>
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Nhập mật khẩu của bạn"
                                   autocomplete="current-password"
                                   id="passwordInput" />
                            <button type="button" class="password-toggle" id="togglePassword" aria-label="Hiện hoặc ẩn mật khẩu">
                                <i class="bi bi-eye" id="toggleIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <!-- Remember me -->
                    <div class="form-group">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="form-check">
                                <input asp-for="RememberMe"
                                       class="form-check-input"
                                       type="checkbox"
                                       id="rememberMe">
                                <label asp-for="RememberMe"
                                       class="form-check-label"
                                       for="rememberMe">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="text-decoration-none small" aria-label="Mở trang quên mật khẩu">
                                Quên mật khẩu?
                            </a>
                        </div>
                    </div>

                    <!-- Submit button -->
                    <button type="submit" class="btn-login" id="submitBtn" aria-label="Đăng nhập hệ thống">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Đăng nhập hệ thống
                    </button>
                </form>
            </div>

            <!-- Footer -->
            <div class="login-footer">
                <div class="footer-info">
                    <i class="bi bi-shield-check"></i>
                    <span>Chỉ dành cho Admin và Cán bộ Đoàn</span>
                </div>
            </div>
        </div>

    </div>
@section Scripts {
    <script src="~/js/auth-login.js" asp-append-version="true"></script>
}
