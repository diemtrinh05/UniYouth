@using UniYouth.Admin.Models.ViewModels.Auth
@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Gửi mã OTP";
    Layout = "_AuthLayout";
}

<main class="auth-flow-container">
    <section class="auth-flow-card">
        <div class="card-body p-4 p-md-5">
            <div class="mb-3">
                <a asp-controller="Account" asp-action="Login" class="auth-flow-back-link text-decoration-none small" aria-label="Quay lại trang đăng nhập">
                    <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Quay lại đăng nhập
                </a>
            </div>

            <h1 class="h3 auth-flow-title mb-2">
                <span class="auth-flow-title-icon me-2">
                    <i class="bi bi-envelope" aria-hidden="true"></i>
                </span>
                Gửi mã OTP
            </h1>
            <p class="auth-flow-description mb-4">
                Nhập tài khoản để nhận mã OTP gồm 6 chữ số và tiếp tục đặt lại mật khẩu.
            </p>

            <div class="auth-flow-note mb-4" role="note">
                <div class="fw-semibold mb-1">Cách hoạt động</div>
                <div class="small text-muted">
                    Hệ thống sẽ gửi OTP về email đã đăng ký của tài khoản này. Sau đó bạn sẽ chuyển sang bước xác thực OTP.
                </div>
            </div>

            <partial name="_Alerts" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="ForgotPassword" method="post" id="forgotPasswordForm">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="forgotPasswordAccount" class="form-label">Tài khoản</label>
                    <input asp-for="Account"
                           id="forgotPasswordAccount"
                           class="form-control"
                           placeholder="Nhập tài khoản"
                           autocomplete="username" />
                    <span asp-validation-for="Account" class="text-danger"></span>
                </div>

                <button type="submit" id="forgotPasswordSubmitButton" class="btn btn-primary w-100" aria-label="Gửi mã OTP đặt lại mật khẩu">
                    <span class="default-label">
                        <i class="bi bi-send me-1" aria-hidden="true"></i>Gửi mã OTP
                    </span>
                    <span class="loading-label d-none">
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        Đang gửi...
                    </span>
                </button>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    <script src="~/js/auth-recovery.js" asp-append-version="true" data-auth-recovery></script>
}
