@using UniYouth.Admin.Models.ViewModels.Auth
@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
    Layout = "_AuthLayout";
    var isLegacyTokenFlow = Model.IsLegacyTokenFlow || !string.IsNullOrWhiteSpace(Model.Token);
    var introText = isLegacyTokenFlow
        ? "Nhập mật khẩu mới để hoàn tất việc đặt lại mật khẩu từ liên kết cũ."
        : "OTP của bạn đã được xác thực. Nhập mật khẩu mới để hoàn tất việc đặt lại mật khẩu.";
    var securityHint = isLegacyTokenFlow
        ? "Liên kết đặt lại mật khẩu cũ vẫn được hỗ trợ trong giai đoạn chuyển tiếp."
        : "Thông tin xác thực đặt lại mật khẩu đang được giữ tạm thời ở phía server.";
}

<main class="auth-flow-container">
    <section class="auth-flow-card">
        <div class="card-body p-4 p-md-5">
            <div class="mb-3">
                <a asp-controller="Account" asp-action="Login" class="auth-flow-back-link text-decoration-none small" aria-label="Quay lại trang đăng nhập">
                    <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Quay lại đăng nhập
                </a>
            </div>

            <h1 class="h3 auth-flow-title mb-2">
                <span class="auth-flow-title-icon me-2">
                    <i class="bi bi-key" aria-hidden="true"></i>
                </span>
                Đặt lại mật khẩu
            </h1>
            <p class="auth-flow-description mb-4">
                @introText
            </p>

            <div class="auth-flow-note mb-4" role="note">
                <div class="fw-semibold mb-1">Trạng thái phiên đặt lại mật khẩu</div>
                <div class="small text-muted">
                    @securityHint
                </div>
            </div>

            <partial name="_Alerts" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" role="alert">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="ResetPassword" method="post" id="resetPasswordForm">
                @Html.AntiForgeryToken()
                @if (isLegacyTokenFlow)
                {
                    <input type="hidden" asp-for="Token" />
                    <input type="hidden" asp-for="IsLegacyTokenFlow" />
                }

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label">Mật khẩu mới</label>
                    <input asp-for="NewPassword"
                           id="newPasswordInput"
                           class="form-control"
                           type="password"
                           autocomplete="new-password" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                    <div class="form-text">Tối thiểu 8 ký tự.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu mới</label>
                    <input asp-for="ConfirmPassword"
                           id="confirmPasswordInput"
                           class="form-control"
                           type="password"
                           autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" id="resetPasswordSubmitButton" class="btn btn-primary w-100" aria-label="Xác nhận đặt lại mật khẩu">
                    <span class="default-label">
                        <i class="bi bi-check2-circle me-1" aria-hidden="true"></i>Xác nhận
                    </span>
                    <span class="loading-label d-none">
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        Đang cập nhật...
                    </span>
                </button>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    <script src="~/js/auth-recovery.js" asp-append-version="true" data-auth-recovery></script>
}
