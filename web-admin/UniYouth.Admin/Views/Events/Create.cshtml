@model UniYouth.Admin.Models.ViewModels.Events.CreateEventViewModel
@{
    ViewData["Title"] = "Tạo sự kiện mới";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <link rel="stylesheet" href="~/css/events-form.css" asp-append-version="true" />
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="bi bi-plus-circle me-2"></i>
        Tạo sự kiện mới
    </h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

<div class="card mb-4">
    <div class="card-header bg-light">
        <strong><i class="bi bi-diagram-3 me-2"></i>Tạo sự kiện theo từng nhóm thông tin</strong>
    </div>
    <div class="card-body">
        <div class="event-inline-note mb-3">
            Điền theo thứ tự: <strong>thông tin cơ bản</strong> → <strong>thời gian</strong> → <strong>địa điểm/GPS</strong> → <strong>check-in policy</strong>.
            Các trường bắt buộc đều có dấu <span class="event-required-dot">*</span>.
        </div>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert">
                <div class="fw-semibold mb-1">Không thể tạo sự kiện do dữ liệu chưa hợp lệ.</div>
                <div class="small">Kiểm tra lại từng nhóm thông tin bên dưới, đặc biệt là thời gian, địa điểm và chính sách check-in.</div>
            </div>

            <section class="event-section-card">
                <div class="event-section-header">
                    <div class="event-section-kicker"><i class="bi bi-card-text"></i>Nhóm 1</div>
                    <h2 class="h5 event-section-title">Thông tin cơ bản</h2>
                    <p class="event-section-description">Xác định tên sự kiện, mô tả, loại sự kiện, đơn vị phụ trách và trạng thái ban đầu.</p>
                </div>
                <div class="event-section-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="EventName" class="form-label fw-bold"></label><span class="event-required-dot"> *</span>
                            <input asp-for="EventName" class="form-control" placeholder="Ví dụ: Hội thảo chuyển đổi số tháng 4" />
                            <div class="form-text">Tên nên đủ rõ để người tham gia nhận ra ngay trên app và web admin.</div>
                            <span asp-validation-for="EventName" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Tóm tắt mục tiêu, nội dung chính và lưu ý khi tham gia"></textarea>
                            <div class="form-text">Mô tả này được dùng để giải thích nhanh cho người tham gia trước khi đăng ký/check-in.</div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EventTypeId" class="form-label fw-bold"></label><span class="event-required-dot"> *</span>
                            <select asp-for="EventTypeId" class="form-select">
                                <option value="">-- Chọn loại sự kiện --</option>
                                @foreach (var t in Model.EventTypes.OrderBy(x => x.TypeId))
                                {
                                    <option value="@t.TypeId">@t.TypeName</option>
                                }
                            </select>
                            <span asp-validation-for="EventTypeId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="InstituteId" class="form-label fw-bold"></label>
                            @{
                                var instituteDisplay = Model.InstituteId switch
                                {
                                    1 => "Viện Công Nghệ Số",
                                    int value => $"Institute #{value}",
                                    _ => "—"
                                };
                            }
                            <input class="form-control" value="@instituteDisplay" readonly aria-label="Đơn vị tổ chức" />
                            <input type="hidden" asp-for="InstituteId" />
                            <div class="form-text">Đơn vị tổ chức được lấy từ phạm vi quản trị hiện tại.</div>
                            <span asp-validation-for="InstituteId" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Status" class="form-label fw-bold"></label><span class="event-required-dot"> *</span>
                            <select asp-for="Status" class="form-select">
                                <option value="0">Nháp (Draft)</option>
                                <option value="1">Mở đăng ký (Open)</option>
                                <option value="2">Đang diễn ra (Ongoing)</option>
                            </select>
                            <div class="form-text">Nếu chưa chắc dữ liệu đã hoàn chỉnh, nên để trạng thái <strong>Nháp</strong>.</div>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="event-section-card">
                <div class="event-section-header">
                    <div class="event-section-kicker"><i class="bi bi-clock-history"></i>Nhóm 2</div>
                    <h2 class="h5 event-section-title">Thời gian & đăng ký</h2>
                    <p class="event-section-description">Thiết lập khung giờ diễn ra, hạn đăng ký và số lượng tối đa.</p>
                </div>
                <div class="event-section-body">
                    <div class="event-inline-note mb-3">
                        Luôn kiểm tra logic thời gian: <strong>Hạn đăng ký</strong> phải trước <strong>Thời gian bắt đầu</strong>, và <strong>Thời gian kết thúc</strong> phải sau <strong>Thời gian bắt đầu</strong>.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="StartTime" class="form-label fw-bold"></label><span class="event-required-dot"> *</span>
                            <input asp-for="StartTime" type="text" class="form-control js-ampm-datetime" asp-format="{0:yyyy-MM-ddTHH:mm}" autocomplete="off" />
                            <span asp-validation-for="StartTime" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndTime" class="form-label fw-bold"></label><span class="event-required-dot"> *</span>
                            <input asp-for="EndTime" type="text" class="form-control js-ampm-datetime" asp-format="{0:yyyy-MM-ddTHH:mm}" autocomplete="off" />
                            <span asp-validation-for="EndTime" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RegistrationDeadline" class="form-label fw-bold"></label>
                            <input asp-for="RegistrationDeadline" type="text" class="form-control js-ampm-datetime" asp-format="{0:yyyy-MM-ddTHH:mm}" autocomplete="off" />
                            <div class="form-text">Để trống nếu không cần khóa đăng ký trước giờ bắt đầu.</div>
                            <span asp-validation-for="RegistrationDeadline" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MaxParticipants" class="form-label fw-bold"></label>
                            <input asp-for="MaxParticipants" type="number" class="form-control" placeholder="Để trống nếu không giới hạn" />
                            <div class="form-text">Nếu để trống, hệ thống hiểu là sự kiện không giới hạn số lượng.</div>
                            <span asp-validation-for="MaxParticipants" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="event-section-card">
                <div class="event-section-header">
                    <div class="event-section-kicker"><i class="bi bi-geo-alt"></i>Nhóm 3</div>
                    <h2 class="h5 event-section-title">Địa điểm & GPS check-in</h2>
                    <p class="event-section-description">Chọn vị trí tổ chức, tọa độ chuẩn và bán kính hợp lệ khi người dùng check-in.</p>
                </div>
                <div class="event-section-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold" for="locationPresetSelect">Vị trí định sẵn</label>
                            <select id="locationPresetSelect" class="form-select">
                                <option value="">-- Không dùng vị trí định sẵn --</option>
                                @foreach (var p in (Model.LocationPresets ?? new()).OrderBy(x => x.Name))
                                {
                                    <option value="@p.LocationPresetId"
                                            data-name="@p.Name"
                                            data-address="@p.Address"
                                            data-lat="@p.Latitude"
                                            data-lng="@p.Longitude"
                                            data-radius="@p.RadiusMeters">
                                        @p.Name
                                    </option>
                                }
                            </select>
                            <div class="form-text">Dùng preset khi địa điểm đã chuẩn hóa để tránh sai lệch tọa độ giữa các sự kiện.</div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AllowRadius" class="form-label fw-bold"></label><span class="event-required-dot"> *</span>
                            <input asp-for="AllowRadius" type="number" class="form-control" />
                            <div class="form-text">Bán kính hợp lệ khi check-in. Nên có buffer thực tế, ví dụ 30m, 50m hoặc 100m.</div>
                            <span asp-validation-for="AllowRadius" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#eventLocationFields"
                                    aria-expanded="false"
                                    aria-controls="eventLocationFields"
                                    aria-label="Mở khu vực bản đồ và tọa độ khi tạo sự kiện">
                                <i class="bi bi-map me-1"></i>Mở khu vực bản đồ & tọa độ
                            </button>
                            <small class="text-muted ms-2">Dùng khi cần chọn GPS chính xác hoặc lấy địa điểm hiện tại.</small>
                        </div>
                    </div>

                    <div id="eventLocationFields" class="collapse mt-3">
                        <div class="event-inline-note mb-3">
                            Nếu bật check-in GPS, đây là nhóm dữ liệu quan trọng nhất. Hãy ưu tiên dùng <strong>preset</strong> hoặc <strong>GPS hiện tại</strong>, sau đó kiểm tra lại tên địa điểm hiển thị.
                        </div>
                        <div class="mb-3">
                            <label asp-for="LocationName" class="form-label fw-bold"></label><span class="event-required-dot"> *</span>
                            <input asp-for="LocationName" class="form-control" placeholder="Ví dụ: Hội trường A, Viện Công Nghệ Số" />
                            <span asp-validation-for="LocationName" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <input asp-for="Latitude" type="hidden" />
                            <input asp-for="Longitude" type="hidden" />

                            <div class="col-md-8 mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <label class="form-label fw-bold mb-0">Vị trí trên bản đồ</label>
                                    <button id="btnUseMyLocation" type="button" class="btn btn-sm btn-outline-primary" aria-label="Dùng GPS hiện tại cho vị trí sự kiện mới">
                                        <i class="bi bi-geo-alt"></i> Dùng GPS hiện tại
                                    </button>
                                </div>
                                <div id="eventLocationMap" class="event-location-map"></div>
                                <div class="event-location-meta small text-muted mt-2">
                                    <span id="eventLocationCoords">Chưa chọn vị trí</span>
                                    <span id="eventLocationStatus"></span>
                                </div>
                                <div>
                                    <span asp-validation-for="Latitude" class="text-danger"></span>
                                    <span asp-validation-for="Longitude" class="text-danger"></span>
                                </div>
                                <small class="text-muted">Click lên bản đồ hoặc nhập địa điểm để lấy tọa độ. Tọa độ hợp lệ sẽ tự lưu vào form.</small>
                            </div>
                            <div class="col-md-4 mb-3">
                                <div class="event-inline-note h-100">
                                    <div class="fw-semibold mb-2">Checklist GPS</div>
                                    <ul class="event-help-list">
                                        <li>Chọn vị trí trung tâm thật sự của điểm check-in.</li>
                                        <li>Không đặt bán kính quá sát nếu địa điểm trong nhà hoặc GPS dễ lệch.</li>
                                        <li>Nếu tọa độ chưa rõ, dùng nút GPS rồi kiểm tra lại tên địa điểm.</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="event-section-card">
                <div class="event-section-header">
                    <div class="event-section-kicker"><i class="bi bi-shield-check"></i>Nhóm 4</div>
                    <h2 class="h5 event-section-title">Check-in policy & rule liên quan</h2>
                    <p class="event-section-description">Xác định sự kiện có dùng xác thực khuôn mặt hay không và các lưu ý vận hành trước khi mở QR/check-in.</p>
                </div>
                <div class="event-section-body">
                    <div class="mb-3 form-check form-switch">
                        <input asp-for="EnableFaceVerification" class="form-check-input" />
                        <label asp-for="EnableFaceVerification" class="form-check-label fw-bold"></label>
                        <div class="form-text">
                            Bật tùy chọn này nếu muốn <strong>bắt buộc người tham gia chụp khuôn mặt khi check-in</strong>.
                            Khi bật, check-in chỉ hợp lệ nếu GPS đạt yêu cầu và khuôn mặt được hệ thống xác nhận đạt điều kiện của sự kiện.
                        </div>
                    </div>

                    <div class="event-inline-note">
                        <div class="fw-semibold mb-2">Khi nào nên bật xác thực khuôn mặt?</div>
                        <ul class="event-help-list">
                            <li>Bật cho sự kiện cần siết kiểm soát người tham gia hoặc hạn chế check-in hộ.</li>
                            <li>Tắt nếu địa điểm đông, ánh sáng kém hoặc quy trình cần diễn ra rất nhanh.</li>
                            <li>Nếu bật face verification, nên kiểm tra trước camera, mạng và vị trí check-in thực tế.</li>
                        </ul>
                    </div>
                </div>
            </section>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <a asp-action="Index" class="btn btn-outline-secondary" aria-label="Hủy tạo sự kiện và quay lại danh sách">
                    <i class="bi bi-x-circle me-1"></i>Hủy bỏ
                </a>
                <button type="submit" class="btn btn-primary" aria-label="Tạo sự kiện mới">
                    <i class="bi bi-check-circle me-1"></i>Tạo sự kiện
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_GoogleMapsScript" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/event-location-picker.js" asp-append-version="true"></script>
    <script src="~/js/events-form.js" asp-append-version="true"></script>
}
