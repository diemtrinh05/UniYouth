@model UniYouth.Admin.Models.ViewModels.SupportChat.SupportChatDetailViewModel
@inject IConfiguration Configuration
@{
    ViewData["Title"] = $"Hỗ trợ #{Model.Conversation.ConversationId}";
    var conversation = Model.Conversation;
    var messages = Model.Messages;
    var apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? string.Empty).TrimEnd('/');
    var supportChatHubUrl = Configuration["SupportChat:HubUrl"] ?? (string.IsNullOrWhiteSpace(apiBaseUrl) ? string.Empty : $"{apiBaseUrl}/hubs/support-chat");
}

<partial name="_Alerts" />

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <a class="btn btn-sm btn-outline-secondary mb-3" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
        </a>
        <h1 class="h3 mb-1">
            <i class="bi bi-chat-left-text me-2"></i>@conversation.Subject
        </h1>
        <div class="text-muted">
            Sinh viên: <strong>@conversation.StudentFullName</strong> (@conversation.StudentCode)
        </div>
    </div>
    <div class="text-end">
        <div class="mb-2">
            <span class="badge @(conversation.Status == 3 ? "bg-secondary" : conversation.Status == 2 ? "bg-info text-dark" : "bg-success")">
                @conversation.StatusName
            </span>
            <span class="badge @(conversation.Priority == 3 ? "bg-danger" : conversation.Priority == 2 ? "bg-warning text-dark" : "bg-light text-dark border")">
                @conversation.PriorityName
            </span>
        </div>
        <div class="small text-muted">Cập nhật: @conversation.UpdatedDate.ToString("dd/MM/yyyy HH:mm")</div>
    </div>
</div>

<div id="supportChatRealtimeBanner"
     class="alert alert-info d-none align-items-center justify-content-between"
     role="status"
     data-support-chat-realtime="detail"
     data-conversation-id="@conversation.ConversationId"
     data-hub-url="@supportChatHubUrl"
     data-token-url="@Url.Action("RealtimeToken", "SupportChat")">
    <div>
        <i class="bi bi-broadcast-pin me-1"></i>
        Cuộc trò chuyện có cập nhật mới. Hãy tải lại để xem nội dung mới nhất.
    </div>
    <button type="button" class="btn btn-sm btn-primary" data-support-chat-reload aria-label="Tải lại cuộc trò chuyện hỗ trợ">Tải lại</button>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card support-chat-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <strong><i class="bi bi-chat-dots me-2"></i>Nội dung trao đổi</strong>
                <span class="small text-muted">@messages.Count tin nhắn trên trang</span>
            </div>
            <div class="card-body support-chat-messages">
                @if (messages.Any())
                {
                    @foreach (var message in messages)
                    {
                        var isMine = message.IsMine;
                        var displayContent = message.Content?.Trim() ?? string.Empty;
                        <div class="d-flex mb-3 @(isMine ? "justify-content-end" : "justify-content-start")">
                            <div class="support-chat-bubble @(isMine ? "support-chat-bubble-mine" : "support-chat-bubble-other")">
                                <div class="small fw-semibold mb-1">
                                    @message.SenderFullName
                                    <span class="text-muted fw-normal">(@message.SenderCode)</span>
                                </div>
                                <div class="support-chat-content">@displayContent</div>
                                @if (!string.IsNullOrWhiteSpace(message.AttachmentUrl))
                                {
                                    <a class="support-chat-attachment d-inline-flex align-items-center gap-1 mt-2"
                                       href="@Html.ResolveApiAssetUrl(message.AttachmentUrl)"
                                       target="_blank"
                                       rel="noopener">
                                        <i class="bi bi-paperclip"></i>
                                        Xem file minh chứng
                                    </a>
                                }
                                <div class="small text-muted mt-2">@message.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-chat-square display-6"></i>
                        <div class="mt-2">Chưa có tin nhắn nào trong cuộc trò chuyện này.</div>
                    </div>
                }
            </div>
            <div class="card-footer bg-white">
                @if (conversation.Status == 3)
                {
                    <div class="alert alert-secondary mb-0">
                        <i class="bi bi-lock me-1"></i>Cuộc trò chuyện đã đóng. Hãy mở lại trạng thái nếu cần trả lời thêm.
                    </div>
                }
                else
                {
                    <form asp-action="SendMessage" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="conversationId" value="@conversation.ConversationId" />
                        <label class="form-label">Phản hồi</label>
                        <textarea class="form-control" asp-for="SendMessage.Content" rows="4" maxlength="4000" placeholder="Nhập nội dung phản hồi cho sinh viên..." aria-label="Nhập nội dung phản hồi cho sinh viên"></textarea>
                        <span class="text-danger small" asp-validation-for="SendMessage.Content"></span>
                        <div class="d-flex justify-content-end mt-3">
                            <button class="btn btn-primary" type="submit" aria-label="Gửi phản hồi cho sinh viên">
                                <i class="bi bi-send me-1"></i>Gửi phản hồi
                            </button>
                        </div>
                    </form>
                    <hr />
                    <form asp-action="SendAttachment" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="conversationId" value="@conversation.ConversationId" />
                        <label class="form-label">Gửi file minh chứng</label>
                        <input class="form-control mb-2" type="file" name="file" accept=".jpg,.jpeg,.png,.webp,.pdf" aria-label="Chọn file minh chứng để gửi cho sinh viên" />
                        <input class="form-control" type="text" name="content" maxlength="1000" placeholder="Ghi chú cho file minh chứng (không bắt buộc)" aria-label="Ghi chú cho file minh chứng" />
                        <div class="form-text">Hỗ trợ JPG, PNG, WebP, PDF. Tối đa 5MB/file.</div>
                        <div class="d-flex justify-content-end mt-3">
                            <button class="btn btn-outline-primary" type="submit" aria-label="Gửi file minh chứng cho sinh viên">
                                <i class="bi bi-paperclip me-1"></i>Gửi minh chứng
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-header bg-white">
                <strong><i class="bi bi-info-circle me-2"></i>Thông tin xử lý</strong>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-5">Mã yêu cầu</dt>
                    <dd class="col-7">#@conversation.ConversationId</dd>

                    <dt class="col-5">Người phụ trách</dt>
                    <dd class="col-7">@(conversation.AssignedToFullName ?? "Chưa phân công")</dd>

                    <dt class="col-5">Ngày tạo</dt>
                    <dd class="col-7">@conversation.CreatedDate.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-5">Đóng lúc</dt>
                    <dd class="col-7">@(conversation.ClosedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-white">
                <strong><i class="bi bi-arrow-repeat me-2"></i>Cập nhật trạng thái</strong>
            </div>
            <div class="card-body">
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="conversationId" value="@conversation.ConversationId" />
                    <select class="form-select mb-3" asp-for="UpdateStatus.Status" aria-label="Chọn trạng thái yêu cầu hỗ trợ">
                        <option value="1">Mới</option>
                        <option value="2">Đang xử lý</option>
                        <option value="3">Đã đóng</option>
                    </select>
                    <button class="btn btn-outline-primary w-100" type="submit" aria-label="Cập nhật trạng thái yêu cầu hỗ trợ">
                        <i class="bi bi-check2-circle me-1"></i>Cập nhật trạng thái
                    </button>
                </form>
            </div>
        </div>

        @if (ViewBag.IsAdmin == true)
        {
            <div class="card">
                <div class="card-header bg-white">
                    <strong><i class="bi bi-person-check me-2"></i>Phân công phụ trách</strong>
                </div>
                <div class="card-body">
                    <form asp-action="Assign" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="conversationId" value="@conversation.ConversationId" />
                        <label class="form-label">UserID cán bộ/Admin</label>
                        <input class="form-control mb-2" asp-for="Assign.AssignedToUserId" type="number" min="1" placeholder="Nhập UserID người phụ trách" aria-label="Nhập UserID người phụ trách yêu cầu hỗ trợ" />
                        <div class="form-text mb-3">Để trống và lưu nếu muốn bỏ phân công.</div>
                        <button class="btn btn-outline-success w-100" type="submit" aria-label="Lưu phân công phụ trách yêu cầu hỗ trợ">
                            <i class="bi bi-save me-1"></i>Lưu phân công
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/support-chat.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/support-chat-realtime.js" asp-append-version="true"></script>
    <script src="~/js/support-chat-detail.js" asp-append-version="true"></script>
}
